# Скопируй в .env и подправь под себя:
#   cp .env.example .env

# Postgres
POSTGRES_DB=beer
POSTGRES_USER=beer_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Database URL — для локального go run (host=localhost).
# В docker-compose переопределяется на host=postgres.
DATABASE_URL=postgres://beer_user:change_me@localhost:5432/beer?sslmode=disable

# beer-api (HTTP)
HTTP_LISTEN_ADDR=:8080
ORDER_SERVICE_ADDR=localhost:50051

# order-service (gRPC)
GRPC_LISTEN_ADDR=:50051

# Kafka — для локального go run (внешний listener Kafka на 9094).
# В docker-compose сервисы используют kafka:9092 (внутренний listener).
KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC_ORDERS_READY=orders.ready
KAFKA_GROUP_ID=notification-service
